APP_ENV=development
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SEC_USER_AGENT=stock-analyzer/0.1 (contact: you@example.com)
SEC_TICKER_MAPPING_URL=https://www.sec.gov/files/company_tickers.json
SEC_SUBMISSIONS_BASE_URL=https://data.sec.gov
SEC_ARCHIVES_BASE_URL=https://www.sec.gov
YFINANCE_HISTORY_PERIOD=1y
YFINANCE_HISTORY_INTERVAL=1mo
ANALYSIS_INPUT_SCHEMA_VERSION=v1
RELATIVE_MODEL_PATH=backend/outputs/models/lgbm_excess_spy.txt
RELATIVE_MODEL_FEATURES_PATH=backend/outputs/reports/lgbm_excess_spy_features.json
RELATIVE_MODEL_PREDICTIONS_PATH=backend/outputs/reports/lgbm_excess_spy_test_preds.csv
RELATIVE_MODEL_SECTOR_PATH=backend/outputs/models/lgbm_excess_sector.txt
RELATIVE_MODEL_SECTOR_FEATURES_PATH=backend/outputs/reports/lgbm_excess_sector_features.json
RELATIVE_MODEL_SECTOR_PREDICTIONS_PATH=backend/outputs/reports/lgbm_excess_sector_test_preds.csv
# L1 RAG — embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# L3 qualitative summary — set to true to enable LLM-generated filing summaries (requires Ollama)
ENABLE_QUALITATIVE_SUMMARY=false
